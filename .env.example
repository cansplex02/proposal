# 네이버 클라우드 Maps Geocoding (주소 → 좌표, 우선) https://www.ncloud.com/product/applicationService/maps
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# 카카오 로컬 API (네이버 미설정 시) https://developers.kakao.com
KAKAO_REST_API_KEY=

# 공공데이터포털 — 소상공인시장진흥공단_상가(상권)정보 API
# https://www.data.go.kr/data/15012005/openapi.do
DATA_GO_KR_SERVICE_KEY=

# 소상공인365 오픈 API (bigdata.sbiz.or.kr 마이페이지 발급)
# https://bigdata.sbiz.or.kr → 이용안내 → 개방·활용 → 오픈 API
SBIZ365_API_KEY=
SBIZ365_API_BASE_URL=https://bigdata.sbiz.or.kr
# 인증 파라미터명 (365는 certKey, 공공데이터는 serviceKey)
SBIZ365_KEY_PARAM=certKey

# 365 API 3종 — 명세서의 URL 경로만 붙여넣기 (또는 data/sbiz365-api-spec.json 사용)
SBIZ365_API_MARKET_MAP_PATH=
SBIZ365_API_SIMPLE_PATH=
SBIZ365_API_DETAIL_PATH=

# 소상공인365 — 업소현황(storSttus) 오픈 API 인증키
# 지역(시도·시군구·행정동)·주요상권 단위 업종별 업소수(반기 비교)
SBIZ365_STORE_KEY=

# 네이버 검색광고 — 도구 > API 사용 관리 (Customer ID, 액세스 라이선스, 비밀키)
# https://searchad.naver.com · 문서 https://naver.github.io/searchad-apidoc/
NAVER_SEARCHAD_CUSTOMER_ID=
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=

# 네이버 개발자센터 — 지역 검색 Open API (지도 Playwright 실패 시 폴백)
# https://developers.naver.com/docs/serviceapi/search/local/local.md
NAVER_OPEN_API_CLIENT_ID=
NAVER_OPEN_API_CLIENT_SECRET=

# /admin/analysis · POST /api/analysis/generate 보호 (선택)
ANALYSIS_ADMIN_SECRET=
